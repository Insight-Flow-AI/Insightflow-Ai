# =============================================================
# InsightFlow AI — Root .gitignore
# =============================================================

# ---------------------------------------------------------------
# Python
# ---------------------------------------------------------------
# Virtual environments
venv/
.venv/
env/
.env/
ENV/
ai-service/venv/
ai-service/.venv/

# Byte-compiled / cached files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
*.whl

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# mypy / pyright type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ---------------------------------------------------------------
# Node.js / Frontend
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity

# Build output
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# ---------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------
.env
.env.*
!.env.example
*.local

# ---------------------------------------------------------------
# Logs & Temporary files
# ---------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
compose_run.log
docker_compose_output.txt

# ---------------------------------------------------------------
# OS generated files
# ---------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.suo
*.user
*.userosscache
*.sln.docstates

# ---------------------------------------------------------------
# Docker
# ---------------------------------------------------------------
# Keep docker files tracked, but ignore local override files
docker-compose.override.yml

# ---------------------------------------------------------------
# Java / Spring Boot (backend)
# ---------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# ---------------------------------------------------------------
# CSV / test data (optional — remove if you want these tracked)
# ---------------------------------------------------------------
test.csv
test_dataset.csv
