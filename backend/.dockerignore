# Ignore raw Java sources and tests (only compiled target/classes is needed)
**/src/
**/target/maven-status/
**/target/maven-archiver/
**/target/surefire-reports/
**/target/generated-sources/
**/target/generated-test-sources/
**/target/test-classes/
**/target/*-SNAPSHOT.jar
**/target/*.jar

# Ignore Maven wrapper and project metadata
.mvn/
mvnw
mvnw.cmd
pom.xml
**/pom.xml
.git/
.idea/
*.iml
run-service.ps1
copy-dependencies.ps1
